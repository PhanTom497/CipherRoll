{
  "name": "cipherroll",
  "version": "0.2.0",
  "private": true,
  "description": "CipherRoll — confidential payroll on Arbitrum Sepolia via the CoFHE coprocessor stack",
  "scripts": {
    "baseline": "npm run compile && npm run test && npm run build:web",
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "sync:interfaces": "ts-node ./scripts/sync-interfaces.ts",
    "deploy:arb-sepolia": "npx hardhat run ./scripts/deploy.ts --network arb-sepolia",
    "deploy:base-sepolia": "npx hardhat run ./scripts/deploy.ts --network base-sepolia",
    "smoke:arb-sepolia:wrapper": "npx hardhat run ./scripts/live-smoke-wrapper-arb-sepolia.ts --network arb-sepolia",
    "lint:web": "npm --prefix web run lint",
    "build:web": "npm --prefix web run build"
  },
  "devDependencies": {
    "@cofhe/hardhat-plugin": "0.5.1",
    "@cofhe/mock-contracts": "0.5.1",
    "@cofhe/sdk": "0.5.1",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.7",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.7",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "dotenv": "^16.4.5",
    "hardhat": "2.28.6",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@fhenixprotocol/cofhe-contracts": "0.1.3",
    "@openzeppelin/contracts": "^5.4.0"
  }
}
