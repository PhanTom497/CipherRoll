# Shared chain and deployment values
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
DEPLOYER_PRIVATE_KEY=0xyour_private_key
NEXT_PUBLIC_CIPHERROLL_TARGET_CHAIN=arb-sepolia
NEXT_PUBLIC_CIPHERROLL_CONTRACT_ADDRESS=0xYourCipherRollDeployment
NEXT_PUBLIC_CIPHERROLL_AUDITOR_DISCLOSURE_ADDRESS=0xYourAuditorDisclosureDeployment
NEXT_PUBLIC_CIPHERROLL_DIRECT_SETTLEMENT_ADAPTER=0xYourDirectSettlementAdapter
NEXT_PUBLIC_CIPHERROLL_WRAPPER_SETTLEMENT_ADAPTER=0xYourWrapperSettlementAdapter
NEXT_PUBLIC_DEFAULT_ORG_ID=wave1-demo-org

# Frontend -> backend
# Local example:
NEXT_PUBLIC_CIPHERROLL_BACKEND_BASE_URL=http://127.0.0.1:4000
# Hosted example:
# NEXT_PUBLIC_CIPHERROLL_BACKEND_BASE_URL=https://cipherroll-backend.example.com

# Backend bind and persistence
# Local bind:
CIPHERROLL_BACKEND_HOST=127.0.0.1
CIPHERROLL_BACKEND_PORT=4000
CIPHERROLL_BACKEND_DB_PATH=backend/data/cipherroll-index.sqlite
# Hosted bind:
# CIPHERROLL_BACKEND_HOST=0.0.0.0
# Many platforms inject PORT automatically. If yours does, you usually do not need to set CIPHERROLL_BACKEND_PORT.
# PORT=4000
# Hosted persistent volume example:
# CIPHERROLL_BACKEND_DB_PATH=/data/cipherroll-index.sqlite

# Backend runtime
CIPHERROLL_INDEXER_POLL_INTERVAL_MS=30000
CIPHERROLL_INDEXER_CHUNK_SIZE=50000
# Optional if you want to limit or speed up the first backfill:
# CIPHERROLL_INDEXER_START_BLOCK=265000000
# Optional if you want to protect POST /api/admin/reindex:
# CIPHERROLL_BACKEND_ADMIN_TOKEN=change-me

# Optional if you want CipherBot to use a hosted LLM instead of local retrieval-only fallback:
# GOOGLE_API_KEY=your_google_ai_api_key
# GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key
# GOOGLE_GEMINI_MODEL=gemini-2.5-flash
